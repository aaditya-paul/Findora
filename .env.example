NVIDIA_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# Path to your browser's User Data dir (Chrome/Brave/Edge) — enables real-profile scraping
# Chrome:  C:/Users/<user>/AppData/Local/Google/Chrome/User Data
# Brave:   C:/Users/<user>/AppData/Local/BraveSoftware/Brave-Browser/User Data
# Edge:    C:/Users/<user>/AppData/Local/Microsoft/Edge/User Data
CHROME_USER_DATA=C:/Users/<your-username>/AppData/Local/BraveSoftware/Brave-Browser/User Data
# Path to the browser executable (leave empty to use Playwright's bundled Chromium)
BROWSER_EXECUTABLE=C:/Program Files/BraveSoftware/Brave-Browser/Application/brave.exe
